{
  "name": "local-base",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "local-base": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "README.md"
  ],
  "scripts": {
    "local-base": "bun run src/cli.ts",
    "check": "bun run src/cli.ts --help",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build src/cli.ts --compile --outfile dist/local-base",
    "build:js": "bun build src/cli.ts --target=bun --outfile dist/cli.js"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.5",
    "@inquirer/prompts": "^7.8.4"
  }
}
