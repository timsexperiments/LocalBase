{
  "name": "local-base",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "local-base": "bun run src/cli.ts",
    "format": "bunx prettier --write src",
    "check": "bunx prettier --check src && bun run typecheck && bun run src/cli.ts --help",
    "typecheck": "bunx tsgo --noEmit",
    "build": "bun build src/cli.ts --compile --outfile dist/local-base",
    "build:whisper": "bun run scripts/build-whisper.ts"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^4.0.16",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260620.1",
    "ai": "^7.0.31",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.4",
    "drizzle-orm": "^0.44.5",
    "zod": "^4.4.3"
  }
}
